{
  "name": "snp-crcli",
  "version": "3.1.9",
  "description": "Crawl a website or Google Slides deck and save screenshots as PNG, JPEG, PPTX, or DOCX with visual stability detection.",
  "main": "bin/snp.js",
  "bin": {
    "snp": "./bin/snp.js"
  },
  "scripts": {
    "postinstall": "playwright install chromium || true"
  },
  "keywords": [
    "screenshot",
    "crawler",
    "cli",
    "playwright",
    "pptx",
    "docx",
    "google-slides"
  ],
  "author": "sace-11",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "docx": "^8.5.0",
    "inquirer": "^8.2.6",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.47.0",
    "pptxgenjs": "^3.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sace-11/snp-crcli.git"
  },
  "bugs": {
    "url": "https://github.com/sace-11/snp-crcli/issues"
  },
  "homepage": "https://github.com/sace-11/snp-crcli#readme"
}
