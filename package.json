{
  "name": "clearpass",
  "version": "4.3.4",
  "description": "Crawl websites or Google Slides and save as PNG, JPEG, PPTX, DOCX, PDF, or MHTML with visual stability detection and TUI.",
  "main": "bin/clearpass.js",
  "bin": {
    "clearpass": "bin/clearpass.js",
    "snp": "bin/clearpass.js"
  },
  "scripts": {
    "postinstall": "playwright install chromium || true"
  },
  "keywords": [
    "screenshot",
    "crawler",
    "cli",
    "playwright",
    "pptx",
    "docx",
    "pdf",
    "mhtml",
    "scraper",
    "markdown",
    "text-extraction",
    "bulk",
    "google-slides"
  ],
  "author": "sace-11",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "4.1.2",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "docx": "^8.5.0",
    "inquirer": "^8.2.6",
    "node-html-markdown": "^1.3.0",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.47.0",
    "pptxgenjs": "^3.12.0",
    "turndown": "^7.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sace-11/clearpass.git"
  },
  "bugs": {
    "url": "https://github.com/sace-11/clearpass/issues"
  },
  "homepage": "https://github.com/sace-11/clearpass#readme"
